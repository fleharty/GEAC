        <Resource path="bams/clean_snv.bam" type="bam"/>
        <Resource path="bams/r2_artefact.bam" type="bam"/>
        <Resource path="bams/end_of_read.bam" type="bam"/>
    </Resources>
    <Panel height="237" name="Panel_clean_snv" width="2592">
