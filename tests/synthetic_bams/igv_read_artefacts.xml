        <Track attributeKey="clean_snv.bam" clazz="org.broad.igv.sam.AlignmentTrack" color="185,185,185" displayMode="EXPANDED" experimentType="OTHER" fontSize="10" id="clean_snv.bam" name="clean_snv.bam" visible="true">
